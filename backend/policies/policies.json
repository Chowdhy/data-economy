{
  "policies": [
    {
      "id": "modify-consent-allowed",
      "action": "modifyConsent",
      "permission": true,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "eq",
          "value": "open"
        }
      ]
    },
    {
      "id": "modify-consent-denied",
      "action": "modifyConsent",
      "permission": false,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "neq",
          "value": "open"
        }
      ]
    },
    {
      "id": "join-study-allowed",
      "action": "joinStudy",
      "permission": true,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "eq",
          "value": "open"
        }
      ]
    }, 
    {
      "id": "join-study-denied",
      "action": "joinStudy",
      "permission": false,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "neq",
          "value": "open"
        }
      ]
    }, 
    {
      "id": "access-data-allowed",
      "action": "accessData",
      "permission": true,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "eq",
          "value": "ongoing"
        }
      ]
    },
    {
      "id": "access-data-denied-not-ongoing",
      "action": "accessData",
      "permission": false,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "neq",
          "value": "ongoing"
        }
      ]
    }
  ]
}