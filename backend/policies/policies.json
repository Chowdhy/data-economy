      "permission": true,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "eq",
          "value": "open"
        }
      ]
    },
    {
      "id": "modify-consent-prohibition",
      "action": "modifyConsent",
      "permission": false,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "neq",
          "value": "open"
        }
      ]
    },
    {
      "id": "required-fields-duty",
      "action": "modifyConsent",
      "duty": true,
      "constraints": [
        {
          "field": "requiredFieldsProvided",
          "operator": "eq",
          "value": true
        }
      ]
    },
    {
      "id": "access-data",
      "action": "accessData",
      "permission": true,
      "constraints": [
        {
          "field": "studyStatus",
          "operator": "eq",
          "value": "ongoing"
        }
      ]
    }
  ]
